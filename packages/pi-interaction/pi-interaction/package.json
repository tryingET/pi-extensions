{
  "name": "@tryinget/pi-interaction",
  "version": "0.2.0",
  "description": "Umbrella interaction-runtime extension package for pi",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryingET/pi-extensions.git",
    "directory": "packages/pi-interaction/pi-interaction"
  },
  "bugs": {
    "url": "https://github.com/tryingET/pi-extensions/issues"
  },
  "homepage": "https://github.com/tryingET/pi-extensions/tree/main/packages/pi-interaction/pi-interaction",
  "keywords": [
    "pi-package",
    "pi-extension",
    "interaction-runtime",
    "input-triggers"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fix": "bash ./scripts/quality-gate.sh fix",
    "lint": "bash ./scripts/quality-gate.sh lint",
    "typecheck": "bash ./scripts/quality-gate.sh typecheck",
    "test": "bash ./scripts/quality-gate.sh test",
    "quality:pre-commit": "bash ./scripts/quality-gate.sh pre-commit",
    "quality:pre-push": "bash ./scripts/quality-gate.sh pre-push",
    "quality:ci": "bash ./scripts/quality-gate.sh ci",
    "check": "npm run quality:ci",
    "release:check:quick": "npm pack --dry-run"
  },
  "files": [
    "index.ts",
    "extensions/input-triggers.ts",
    "src/runtime.js",
    "prompts",
    "examples",
    "policy/security-policy.json",
    "policy/stack-lane.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/input-triggers.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "x-pi-template": {
    "scaffoldMode": "monorepo-package",
    "workspacePath": "packages/pi-interaction/pi-interaction",
    "releaseComponent": "pi-interaction",
    "releaseConfigMode": "component"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@types/node": "22.14.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "dependencies": {
    "@tryinget/pi-editor-registry": "file:../pi-editor-registry",
    "@tryinget/pi-interaction-kit": "file:../pi-interaction-kit",
    "@tryinget/pi-trigger-adapter": "file:../pi-trigger-adapter"
  }
}
