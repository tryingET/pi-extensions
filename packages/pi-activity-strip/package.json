{
  "name": "@tryinget/pi-activity-strip",
  "version": "0.1.0",
  "description": "pi extension package for activity-strip workflows in monorepo runtime",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryingET/pi-extensions.git",
    "directory": "packages/pi-activity-strip"
  },
  "bugs": {
    "url": "https://github.com/tryingET/pi-extensions/issues"
  },
  "homepage": "https://github.com/tryingET/pi-extensions/tree/main/packages/pi-activity-strip",
  "keywords": [
    "pi-package",
    "pi-extension",
    "activity-strip",
    "monorepo"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fix": "bash ./scripts/quality-gate.sh fix",
    "lint": "bash ./scripts/quality-gate.sh lint",
    "typecheck": "bash ./scripts/quality-gate.sh typecheck",
    "quality:pre-commit": "bash ./scripts/quality-gate.sh pre-commit",
    "quality:pre-push": "bash ./scripts/quality-gate.sh pre-push",
    "quality:ci": "bash ./scripts/quality-gate.sh ci",
    "check": "npm run quality:ci",
    "test": "npm run quality:ci",
    "docs:list": "bash ./scripts/docs-list.sh",
    "docs:list:workspace": "bash ./scripts/docs-list.sh --workspace --discover",
    "docs:list:json": "bash ./scripts/docs-list.sh --json",
    "release:check": "bash ./scripts/release-check.sh",
    "release:check:quick": "SKIP_PI_SMOKE=1 bash ./scripts/release-check.sh",
    "strip:open": "node ./bin/pi-activity-strip.mjs open",
    "strip:status": "node ./bin/pi-activity-strip.mjs status",
    "strip:snapshot": "node ./bin/pi-activity-strip.mjs snapshot",
    "strip:fix-top": "node ./bin/pi-activity-strip.mjs fix-top",
    "strip:stop": "node ./bin/pi-activity-strip.mjs stop",
    "capture:strip": "bash ./scripts/capture-strip-window.sh",
    "capture:top": "bash ./scripts/capture-top-band.sh 180",
    "demo:simulate": "node ./examples/simulate-sessions.mjs",
    "smoke:headless-live": "bash ./scripts/live-headless-smoke.sh"
  },
  "files": [
    "bin",
    "extensions/activity-strip.js",
    "extensions/activity-strip.ts",
    "src",
    "prompts",
    "examples",
    "policy/security-policy.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/activity-strip.js"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "x-pi-template": {
    "scaffoldMode": "simple-package",
    "workspacePath": "packages/pi-activity-strip",
    "releaseComponent": "pi-activity-strip",
    "releaseConfigMode": "none"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@mariozechner/pi-coding-agent": "^0.63.1"
  },
  "overrides": {
    "fast-xml-parser": "5.3.6"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  }
}
