{
  "name": "pi-prompt-template-accelerator",
  "version": "0.2.0",
  "description": "pi extension package: pi-prompt-template-accelerator",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryingET/pi-extensions.git",
    "directory": "packages/pi-prompt-template-accelerator"
  },
  "bugs": {
    "url": "https://github.com/tryingET/pi-extensions/issues"
  },
  "homepage": "https://github.com/tryingET/pi-extensions/tree/main/packages/pi-prompt-template-accelerator",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-prompt-template-accelerator"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fix": "bash ./scripts/quality-gate.sh fix",
    "lint": "bash ./scripts/quality-gate.sh lint",
    "typecheck": "bash ./scripts/quality-gate.sh typecheck",
    "test": "bash ./scripts/quality-gate.sh test",
    "quality:pre-commit": "bash ./scripts/quality-gate.sh pre-commit",
    "quality:pre-push": "bash ./scripts/quality-gate.sh pre-push",
    "quality:ci": "bash ./scripts/quality-gate.sh ci",
    "check": "npm run quality:ci",
    "test:smoke:non-ui": "node --import tsx --test tests/non-ui-mixed-extension-smoke.test.ts",
    "test:compat:interaction-runtime": "npm run test:smoke:non-ui",
    "docs:list": "bash ./scripts/docs-list.sh",
    "docs:list:workspace": "bash ./scripts/docs-list.sh --workspace --discover",
    "docs:list:json": "bash ./scripts/docs-list.sh --json",
    "release:check:quick": "npm pack --dry-run",
    "prepack": "node ../pi-interaction/scripts/prepare-publish-manifest.mjs prepack",
    "postpack": "node ../pi-interaction/scripts/prepare-publish-manifest.mjs postpack"
  },
  "pi": {
    "extensions": [
      "./extensions/ptx.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "x-pi-template": {
    "scaffoldMode": "simple-package",
    "workspacePath": "packages/pi-prompt-template-accelerator",
    "releaseComponent": "pi-prompt-template-accelerator",
    "releaseConfigMode": "component"
  },
  "dependencies": {
    "@tryinget/pi-interaction": "file:../pi-interaction/pi-interaction",
    "@tryinget/pi-runtime-registry": "file:../pi-interaction/pi-runtime-registry",
    "@tryinget/pi-trigger-adapter": "file:../pi-interaction/pi-trigger-adapter"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "tsx": "^4.20.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  }
}
