{
  "name": "pi-autonomous-session-control",
  "version": "0.1.0",
  "description": "pi extension package for autonomy-control workflows in pi",
  "type": "module",
  "exports": {
    ".": "./extensions/self.ts",
    "./execution": "./execution.ts"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tryingET/pi-extensions.git",
    "directory": "packages/pi-autonomous-session-control"
  },
  "bugs": {
    "url": "https://github.com/tryingET/pi-extensions/issues"
  },
  "homepage": "https://github.com/tryingET/pi-extensions/tree/main/packages/pi-autonomous-session-control",
  "keywords": [
    "pi-package",
    "pi-extension",
    "autonomy-control"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "fix": "bash ./scripts/quality-gate.sh fix",
    "lint": "bash ./scripts/quality-gate.sh lint",
    "typecheck": "bash ./scripts/quality-gate.sh typecheck",
    "quality:pre-commit": "bash ./scripts/quality-gate.sh pre-commit",
    "quality:pre-push": "bash ./scripts/quality-gate.sh pre-push",
    "quality:ci": "bash ./scripts/quality-gate.sh ci",
    "check": "npm run quality:ci",
    "test": "npm run quality:ci",
    "test:compat:parallel-tool-events": "node --test tests/self/registration.test.mjs tests/self/perception.test.mjs",
    "docs:list": "bash ./scripts/docs-list.sh",
    "docs:list:workspace": "bash ./scripts/docs-list.sh --workspace --discover",
    "docs:list:json": "bash ./scripts/docs-list.sh --json",
    "release:check": "bash ./scripts/release-check.sh",
    "release:check:quick": "SKIP_PI_SMOKE=1 bash ./scripts/release-check.sh"
  },
  "files": [
    "execution.ts",
    "extensions/self.ts",
    "extensions/self",
    "prompts",
    "examples",
    "policy/security-policy.json",
    "policy/stack-lane.json"
  ],
  "pi": {
    "extensions": [
      "./extensions/self.ts"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "x-pi-template": {
    "scaffoldMode": "monorepo-package",
    "workspacePath": "packages/pi-autonomous-session-control",
    "releaseComponent": "pi-autonomous-session-control",
    "releaseConfigMode": "component"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "fast-xml-parser": "5.3.6"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  }
}
