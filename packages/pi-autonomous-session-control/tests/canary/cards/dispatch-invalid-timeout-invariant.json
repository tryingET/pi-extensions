{
  "id": "dispatch-invalid-timeout-invariant",
  "title": "dispatch_subagent rejects negative timeout via invariant guard",
  "target": "dispatch_subagent",
  "calls": [
    {
      "profile": "reviewer",
      "objective": "Review timeout constraints",
      "timeout": -1
    }
  ],
  "assertions": [
    {
      "path": "results.0.details.status",
      "equals": "error"
    },
    {
      "path": "results.0.details.reason",
      "equals": "invariant_failed"
    },
    {
      "path": "results.0.content.0.text",
      "includes": "dispatch.timeout.non_negative"
    }
  ]
}
